# IMPORTANT: DO NOT COMMIT REAL SECRETS
# Copy to .env.local and fill in values.

# Database (DEV ONLY)
# Production money path uses Supabase (serverless-safe).
DATABASE_URL="mysql://root:password@localhost:3306/velvet_alchemy"

# -----------------------------
# Stripe (Capture → Redirect to Payment Link)
# -----------------------------
# REQUIRED for redirect-to-checkout funnel:
STRIPE_PAYMENT_LINK_URL="<SET_ME>"     # https://buy.stripe.com/...

# OPTIONAL unless you are using webhooks / API payment flows:
STRIPE_SECRET_KEY="<SET_ME>"           # sk_test_... or sk_live_...
STRIPE_PUBLISHABLE_KEY="<SET_ME>"      # pk_test_... or pk_live_...
STRIPE_WEBHOOK_SECRET="<SET_ME>"       # whsec_...

# AWS (optional unless you store screenshots/assets in S3)
AWS_ACCESS_KEY_ID="<OPTIONAL>"
AWS_SECRET_ACCESS_KEY="<OPTIONAL>"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="<OPTIONAL>"

# Auth / OAuth
VITE_OAUTH_PORTAL_URL="http://localhost:3000"
VITE_APP_ID="velvet-alchemy"
OAUTH_SERVER_URL="http://localhost:3000"
JWT_SECRET="<SET_ME>"

# Analytics (optional)
VITE_ANALYTICS_ENDPOINT="http://localhost:3000"

# AI Services
OPENAI_API_KEY="<SET_ME>"
GEMINI_API_KEY="<OPTIONAL>"

# Google (optional unless you are using Google APIs/OAuth)
GOOGLE_API_KEY="<OPTIONAL>"
GOOGLE_CLIENT_ID="<OPTIONAL>"
GOOGLE_CLIENT_SECRET="<OPTIONAL>"
GOOGLE_REFRESH_TOKEN="<OPTIONAL>"
GOOGLE_CX_ID="<OPTIONAL>"

# Supabase (REQUIRED for Vercel-safe lead capture)
SUPABASE_URL="<SET_ME>"                 # https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY="<SET_ME>"    # service role key (server-only)

# Cron security (REQUIRED if Vercel cron is enabled)
CRON_SECRET="<SET_ME>"                  # random long string used to auth /api/cron/ghost-followup

# Public base URL (RECOMMENDED; used in Ghost emails)
PUBLIC_APP_URL="<SET_ME>"               # https://yourdomain.com (or your Vercel URL)
